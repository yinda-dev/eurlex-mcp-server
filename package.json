{
  "name": "eurlex-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for EU law via EUR-Lex Cellar API — search, fetch, and analyze EU regulations, directives, and court decisions",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "eurlex-mcp-server": "dist/index.js"
  },
  "files": [
    "dist/",
    "!dist/__tests__/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "start:http": "node dist/http.js",
    "dev:http": "tsx src/http.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test",
    "inspect": "pnpm dlx @modelcontextprotocol/inspector node dist/index.js",
    "test:coverage": "vitest run --coverage",
    "prebuild": "pnpm run typecheck",
    "prepublishOnly": "pnpm run check && pnpm run build",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "eurlex",
    "eur-lex",
    "eu-law",
    "european-union",
    "legal",
    "cellar-api",
    "sparql"
  ],
  "author": "philrox <phil@resultsbymagic.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philrox/eurlex-mcp-server.git"
  },
  "homepage": "https://github.com/philrox/eurlex-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/philrox/eurlex-mcp-server/issues"
  },
  "engines": {
    "node": ">=24.5.0"
  },
  "packageManager": "pnpm@10.30.1",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.3.1",
    "undici": "^8.2.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@eslint/js": "^10.0.1",
    "@types/express": "^4.17.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^2.1.9",
    "esbuild": "^0.25.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^2.0.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
